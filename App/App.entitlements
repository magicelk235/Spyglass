<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- The app is deliberately NOT sandboxed (extensions must be; hosts need
         not be outside the App Store). The Quick Look extension's sandbox is
         write-locked — it can't write the group container, shared prefs, or
         launch apps — so the app must discover stub files on disk itself
         (StubScanner) and pre-fetch previews. That needs real file access.
         The App Group holds the rendered-PDF cache and the Keychain group the
         OAuth token, both shared with the extension. -->
    <key>com.apple.security.application-groups</key>
    <array>
        <string>group.com.spyglass.shared</string>
    </array>
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)com.spyglass.shared</string>
    </array>
</dict>
</plist>
